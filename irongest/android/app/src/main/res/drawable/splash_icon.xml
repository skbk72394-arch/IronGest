<?xml version="1.0" encoding="utf-8"?>
<!--
  IronGest - Splash Screen Icon
  Arc reactor inspired design
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer ring -->
    <item
        android:width="100dp"
        android:height="100dp"
        android:gravity="center">
        <shape android:shape="oval">
            <stroke
                android:width="3dp"
                android:color="#00D4FF" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    
    <!-- Inner ring -->
    <item
        android:width="70dp"
        android:height="70dp"
        android:gravity="center">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#00D4FF" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    
    <!-- Core -->
    <item
        android:width="30dp"
        android:height="30dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#00D4FF" />
        </shape>
    </item>
</layer-list>
